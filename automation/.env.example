#
# Copy this file to `.env` and adjust values.
#
# Required
BASE_URL=https://testing.property.am-bition.jp/
ROOM_LIST_PATH=/room

# Google SSO login page
LOGIN_PATH=/login

# Provide values that exist in your dataset
TEST_PROPERTY_CODE=10001
TEST_PROPERTY_NAME=テスト物件
TEST_PROPERTY_NAME_KANA=てすとぶっけん

# Optional: Playwright storage state path (recommended for login)
# Generate it once by running a small "login" script or by using the browser UI.
PLAYWRIGHT_STORAGE_STATE=./storageState.json

# Used by the storage-state generator to know when you're done logging in.
# It waits until the current URL contains this substring.
LOGGED_IN_URL_CONTAINS=/room

# Optional: Override selectors if the fallbacks don't match your DOM
# PROPERTY_CODE_INPUT_SELECTOR=input[name="propertyCode"]
# PROPERTY_NAME_INPUT_SELECTOR=input[name="propertyName"]
# PROPERTY_NAME_KANA_INPUT_SELECTOR=input[name="propertyNameKana"]
#
# Optional: override copy button selector if it's not reachable from a row
# COPY_BUTTON_SELECTOR=button:has-text("コピー")
#
# Optional: override the search button selector if pressing Enter doesn't filter
# SEARCH_BUTTON_SELECTOR=button:has-text("検索")

